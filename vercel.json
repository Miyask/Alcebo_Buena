{
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/export-docx",
      "destination": "/api/export-docx.ts"
    },
    {
      "source": "/api/transcribe",
      "destination": "/api/transcribe.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
